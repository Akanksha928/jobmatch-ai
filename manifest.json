{
  "manifest_version": 3,
  "name": "JobMatch AI",
  "version": "1.0",
  "description": "Highlights missing resume skills on LinkedIn job pages.",
  "permissions": ["storage", "scripting", "activeTab"],
  "host_permissions": ["http://localhost:4000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.linkedin.com/jobs/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["libs/pdf.worker.js", "libs/pdf.mjs", "panel.css"],
      "matches": ["<all_urls>"]
    }
  ]
}